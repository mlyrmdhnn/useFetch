{
  "name": "vnexum-vue",
  "publishConfig": {
    "access": "public"
  },
  "version": "1.1.2",
  "description": "The data driven toolkit for vue",
  "type": "module",
  "main": "./dist/index.cjs.js",
  "module": "./dist/index.es.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.es.js",
      "require": "./dist/index.cjs.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "vue-tsc --noEmit && vite build"
  },
  "peerDependencies": {
    "vue": "^3.0.0",
    "vue-router": "^5.1.0"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "@vitejs/plugin-vue": "^6.0.7",
    "vite": "^8.0.16",
    "vite-plugin-css-injected-by-js": "^5.0.1",
    "vite-plugin-dts": "^5.0.2",
    "vue-router": "^5.1.0",
    "vue-tsc": "^3.3.3"
  },
  "dependencies": {
    "tailwindcss": "^4.3.2"
  }
}
