{
  "name": "@mlyrmdhnn/use-fetch",
  "version": "1.0.1",
  "description": "Lightweight zero-dependency HTTP composable for Vue 3.5+",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "keywords": [
    "vue",
    "vue3",
    "composable",
    "fetch",
    "typescript",
    "http"
  ],
  "author": "mlyrmdhnn",
  "license": "MIT",
  "peerDependencies": {
    "vue": ">=3.5.0"
  },
  "scripts": {
    "build": "vite build",
    "prepublishOnly": "npm run build"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "typescript": "^6.0.3",
    "vite": "^8.0.14",
    "vite-plugin-dts": "^5.0.1"
  }
}
