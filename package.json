{
  "name": "@mlyrmdhnn/use-fetch",
  "version": "1.0.3",
  "description": "Custom HTTP client and Vue component",
  "type": "module",
  "main": "./dist/index.cjs.js",
  "module": "./dist/index.es.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
