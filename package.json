    "vue": "^3.0.0",
    "vue-router": "^5.1.0"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "@vitejs/plugin-vue": "^6.0.7",
    "vite": "^8.0.16",
    "vite-plugin-dts": "^5.0.2",
    "vue-router": "^5.1.0",
    "vue-tsc": "^3.3.3"
  }
}
